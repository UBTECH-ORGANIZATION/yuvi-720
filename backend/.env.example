# yuvi-720 backend environment — copy to backend/.env and fill in.
# backend/.env is gitignored; NEVER commit real values.

# --- Azure OpenAI via APIM gateway ---
APIM_BASE_URL=
APIM_SUBSCRIPTION_KEY=
APIM_API_VERSION=2024-10-21
LLM_STRONG_DEPLOYMENT_NAME=
LLM_MINI_DEPLOYMENT_NAME=

# --- Database (Cosmos DB for MongoDB vCore) ---
MONGODB_CONNECTION_STRING=

# --- App / hosting ---
FRONTEND_URL=http://localhost:8720
SECRET_KEY=

# --- Azure Speech (read-aloud) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- MoE LRS (720) outbound xAPI reporting ---
# Staging host: lrs-stg.education.gov.il · prod credentials issued by MoE later.
# Reporting is OFF unless LRS_ENABLED=true AND urls+credentials are set.
LRS_ENABLED=false
LRS_TOKEN_URL=https://lrs-stg.education.gov.il/auth/oauth/v2/token
LRS_STATEMENTS_URL=https://lrs-stg.education.gov.il/xAPI/statements
LRS_CLIENT_ID=
LRS_CLIENT_SECRET=
LRS_SCOPE=lrs
LRS_XAPI_VERSION=1.0.3
LRS_SUPPLIER_DOMAIN=https://720.example.co.il
LRS_PROGRAM_IRI=https://lxp.education.gov.il/xapi/moe/program/720-platform
# Kata's item id in the MoE educational catalog (content-vendor grouping); empty until assigned.
LRS_KATA_ECAT_ID=
# Stub reporting identity (staging only) — replaced by real per-learner MoE SSO mapping.
LRS_TEST_EXIDENTIFIER=
LRS_DEFAULT_SCHOOL=
LRS_DEFAULT_NMM=

# --- Kata (CET) content platform — catalog + xAPI launcher ---
KATA_BASE_URL=https://kata.cet.ac.il
KATA_API_KEY=
