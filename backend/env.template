# yuvi-720 environment variables.
#
# LOCAL DEV:  copy this file to backend/.env (gitignored) and fill values.
#             server.py auto-loads backend/.env on startup.
# AZURE:      the SAME keys are set as App Service "Application settings"
#             (container env vars). No .env file ships inside the Docker image.
#
# The app runs WITHOUT any of these (AI features fall back to canned responses),
# but production should set the APIM + Mongo values below.

# --- Azure OpenAI via APIM gateway (reused from the shared cotrade APIM) ---
APIM_BASE_URL=https://apim-cotrade-prod.azure-api.net/openai
APIM_SUBSCRIPTION_KEY=your-apim-subscription-key
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
APIM_API_VERSION=2024-10-21

# Or Azure AI Foundry direct endpoint fallback
# AZURE_AI_FOUNDRY_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
# AZURE_AI_FOUNDRY_API_KEY=your-foundry-key

# --- Database (Cosmos DB for MongoDB vCore) ---
# Provisioned for future use; the current app has no DB code yet.
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@yuvi720.global.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000

# --- App / hosting ---
# Public-facing URL (used for absolute links / OAuth redirects if added later).
FRONTEND_URL=https://spark.yuvilab.ai
# Azure App Service reads WEBSITES_PORT to know which container port to route to.
WEBSITES_PORT=8000