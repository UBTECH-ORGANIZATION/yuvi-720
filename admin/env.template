# Standalone Yuvilab Spark administration service
ADMIN_ENV=development
ADMIN_PORT=9998
ADMIN_BASE_URL=http://localhost:9998
ADMIN_COOKIE_SECURE=false

# Public by default for the current preview. Set false to enable Google admin auth.
ADMIN_PUBLIC_ACCESS=true

# Required when Google auth is enabled. Generate a long random value.
ADMIN_SECRET_KEY=

# Used only when ADMIN_PUBLIC_ACCESS=false.
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Prefer a database credential with read-only access to ai_usage_events.
MONGODB_CONNECTION_STRING=
MONGODB_DATABASE=yuvi720
